{
  "name": "@andrew-nazin/single-flight",
  "version": "1.0.0",
  "description": "TypeScript single-flight implementation for deduplicating concurrent async operations by key.",
  "keywords": [
    "single-flight",
    "singleflight",
    "promise",
    "deduplication",
    "request-coalescing",
    "async",
    "typescript",
    "cache",
    "cooldown"
  ],
  "homepage": "https://github.com/andrew-nazin/single-flight#readme",
  "bugs": {
    "url": "https://github.com/andrew-nazin/single-flight/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrew-nazin/single-flight.git"
  },
  "license": "MIT",
  "author": {
    "name": "Andrew Nazin"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run build && npm run test",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run clean && npm run check"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^4.1.6",
    "rimraf": "^6.1.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
